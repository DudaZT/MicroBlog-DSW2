<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configura o pool de conexões JDBC via JNDI no Tomcat.
-->
<Context>
  <Resource
    name="jdbc/microblog"
    auth="Container"
    type="javax.sql.DataSource"
    maxTotal="20"
    maxIdle="10"
    maxWaitMillis="10000"
    username="root"
    password="root"
    driverClassName="com.mysql.cj.jdbc.Driver"
    url="jdbc:mysql://localhost:3306/microblog?useSSL=false&amp;serverTimezone=America/Sao_Paulo"
  />
</Context>